###> symfony/framework-bundle ###
# Plantilla para producción. Se copia a .env en el deploy (Railway no tiene .env local).
# Las variables definidas en el panel de Railway tienen prioridad sobre estos valores.
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_me_in_railway

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=srm_compras
DATABASE_USER=root
DATABASE_PASSWORD=

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

DEFAULT_URI=http://localhost

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
###< symfony/framework-bundle ###
