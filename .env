# Valores por defecto (desarrollo local). En Railway, las variables del panel tienen prioridad.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_locally

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=srm_compras
DATABASE_USER=root
DATABASE_PASSWORD=

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

DEFAULT_URI=http://127.0.0.1:8000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
